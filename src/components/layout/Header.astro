---
// src/components/layout/Navbar.astro
// Barra de navegación principal de VHAJ
// Sticky con blur, logo SVG + links + CTA

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/services" },
  { label: "Productos", href: "/products" },
  { label: "Nosotros", href: "/abouts" },
];

// const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

// const isActive = (href: string) => {
//   const normalizedHref = href.replace(/\/$/, "") || "/";
//   return currentPath === normalizedHref;
// };

const iconWhatsapp = "https://api.iconify.design/mdi/whatsapp.svg";
---

<header
  class="sticky top-0 z-50 border-b border-[rgba(167,139,250,0.12)] backdrop-blur-xl bg-[rgba(7,7,15,0.7)]"
>
  <div
    class="max-w-300 mx-auto px-12 py-4.5 flex items-center justify-between gap-8"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2.5 shrink-0 no-underline"
      aria-label="VHAJ - Inicio"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 200 200"
        width="32"
        height="32"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#38bdf8"></stop>
            <stop offset="100%" stop-color="#a78bfa"></stop>
          </linearGradient>
        </defs>
        <g fill="url(#logo-grad)">
          <rect x="92" y="20" width="16" height="160"></rect>
          <rect
            x="92"
            y="20"
            width="16"
            height="160"
            transform="rotate(45 100 100)"></rect>
          <rect
            x="92"
            y="20"
            width="16"
            height="160"
            transform="rotate(90 100 100)"></rect>
          <rect
            x="92"
            y="20"
            width="16"
            height="160"
            transform="rotate(135 100 100)"></rect>
        </g>
        <line
          x1="100"
          y1="70"
          x2="100"
          y2="90"
          stroke="#f1f5f9"
          stroke-width="4"
          stroke-linecap="round"
          transform="rotate(45 100 100)"></line>
      </svg>
      <span
        class="brand-gradient font-['Syne'] font-extrabold text-lg tracking-tight"
      >
        VHAJ
      </span>
    </a>

    <!-- Links desktop -->
    <nav aria-label="Navegación principal" class="hidden md:block">
      <ul class="flex gap-9 list-none">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                data-navlink
                class="nav-link text-[17px] no-underline tracking-wide transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-4">
      <a
        href="https://wa.me/573332382830"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contáctanos por WhatsApp"
        class="hidden md:inline-block text-[13px] font-medium
        px-5.5 py-2.25 rounded-lg text-black no-underline transition-all
        duration-200 hover:opacity-85 hover:-translate-y-px btn-gradient"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
      </a>

      <!-- Botón hamburguesa mobile -->
      <button
        id="menu-toggle"
        class="md:hidden flex flex-col gap-1.25 bg-transparent border-none cursor-pointer p-1"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span
          class="block w-5.5 h-0.5 bg-(--text) rounded-sm transition-all duration-300"
        ></span>
        <span
          class="block w-5.5 h-0.5 bg-(--text) rounded-sm transition-all duration-300"
        ></span>
        <span
          class="block w-5.5 h-0.5 bg-(--text) rounded-sm transition-all duration-300"
        ></span>
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="hidden flex-col gap-2 px-6 pb-6 pt-4 border-t border-[rgba(167,139,250,0.12)]"
    aria-hidden="true"
  >
    <ul class="list-none flex flex-col gap-1 mb-4">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              data-navlink
              class="block px-3 py-2.5 text-[17px] no-underline rounded-lg transition-all duration-200"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="https://wa.me/573332382830"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contáctanos por WhatsApp"
      class="flex items-center justify-center text-center text-[17px] font-medium px-4 py-3
    rounded-lg text-black no-underline btn-gradient"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
        ></path>
      </svg>
      <span class="ml-2">Contáctanos</span>
    </a>

    <style>
      /* Gradiente en texto del logo — Tailwind no soporta -webkit-background-clip */
      .brand-gradient {
        background: linear-gradient(135deg, #a78bfa, #38bdf8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Gradiente en botón CTA */
      .btn-gradient {
        background: linear-gradient(135deg, #a78bfa, #38bdf8);
      }

      /* Línea animada bajo los links — requiere ::after */
      .nav-link {
        position: relative;
      }

      .nav-link::after {
        content: "";
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 1px;
        background: linear-gradient(135deg, #a78bfa, #38bdf8);
        transition: width 0.3s;
      }

      .nav-link:hover::after {
        width: 100%;
      }

      .nav-link--active::after {
        width: 100%;
      }
    </style>

    <!-- JavaScript para el menú mobile -->
    <script is:inline>
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const currentPath = window.location.pathname.replace(/\/$/, "") || "/";

      document.querySelectorAll("[data-navlink]").forEach((link) => {
        const href = link.getAttribute("href").replace(/\/$/, "") || "/";
        if (href === currentPath) {
          link.classList.remove("text-(--muted)");
          link.classList.add("text-(--text)", "nav-link--active");
        }
      });

      toggle?.addEventListener("click", () => {
        const isOpen = menu?.classList.toggle("!flex");
        menu?.classList.toggle("hidden", !isOpen);
        toggle.setAttribute("aria-expanded", String(isOpen));
        menu?.setAttribute("aria-hidden", String(!isOpen));
      });

      menu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          menu.classList.remove("!flex");
          menu.classList.add("hidden");
          toggle?.setAttribute("aria-expanded", "false");
          menu.setAttribute("aria-hidden", "true");
        });
      });
    </script>
  </div>
</header>
