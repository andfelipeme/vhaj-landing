---
// src/components/layout/Footer.astro
// Footer principal de VHAJ
// Incluye: logo, links, servicios, redes y copyright

const services = [
  { label: "Desarrollo web", href: "/services" },
  { label: "Sistemas de gestión", href: "/services" },
  { label: "Diseño UI/UX", href: "/services" },
  { label: "Consultoría técnica", href: "/services" },
];

const products = [{ label: "VHAJ POS System", href: "/products" }];

const company = [{ label: "Nosotros", href: "/abouts" }];
---

<footer class="relative z-10 border-t border-[rgba(167,139,250,0.12)]">
  <!-- Contenido principal -->
  <div class="max-w-300 mx-auto px-5 sm:px-8 md:px-12 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 lg:gap-12">
      <!-- Columna 1: Logo + descripción -->
      <div>
        <a href="/" class="inline-flex items-center gap-2.5 no-underline mb-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 200 200"
            width="28"
            height="28"
            aria-hidden="true"
          >
            <defs>
              <linearGradient
                id="footer-grad"
                x1="0%"
                y1="0%"
                x2="100%"
                y2="100%"
              >
                <stop offset="0%" stop-color="#38bdf8"></stop>
                <stop offset="100%" stop-color="#a78bfa"></stop>
              </linearGradient>
            </defs>
            <g fill="url(#footer-grad)">
              <rect x="92" y="20" width="16" height="160"></rect>
              <rect
                x="92"
                y="20"
                width="16"
                height="160"
                transform="rotate(45 100 100)"></rect>
              <rect
                x="92"
                y="20"
                width="16"
                height="160"
                transform="rotate(90 100 100)"></rect>
              <rect
                x="92"
                y="20"
                width="16"
                height="160"
                transform="rotate(135 100 100)"></rect>
            </g>
            <line
              x1="100"
              y1="70"
              x2="100"
              y2="90"
              stroke="#f1f5f9"
              stroke-width="4"
              stroke-linecap="round"
              transform="rotate(45 100 100)"></line>
          </svg>
          <span
            class="brand-gradient font-['Syne'] font-extrabold text-lg tracking-tight"
          >
            VHAJ
          </span>
        </a>

        <!-- Redes sociales -->
        <div class="flex gap-3">
          <a
            href="https://github.com/andfelipeme"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="social-link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/andresfelipeme/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="social-link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
          <a
            href="https://x.com/andfelipeme"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Twitter/X"
            class="social-link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Columna 2: Servicios -->
      <div>
        <h3
          class="font-['Syne'] text-[13px] font-semibold text-(--text) tracking-wide mb-4"
        >
          Servicios
        </h3>
        <ul class="flex flex-col gap-2.5 list-none">
          {
            services.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="footer-link text-[13px] text-(--muted) no-underline transition-colors duration-200 hover:text-(--text)"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna 3: Productos -->
      <div>
        <h3
          class="font-['Syne'] text-[13px] font-semibold text-(--text) tracking-wide mb-4"
        >
          Productos
        </h3>
        <ul class="flex flex-col gap-2.5 list-none">
          {
            products.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="footer-link text-[13px] text-(--muted) no-underline transition-colors duration-200 hover:text-(--text)"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>

        <h3
          class="font-['Syne'] text-[13px] font-semibold text-(--text) tracking-wide mb-4 mt-8"
        >
          Empresa
        </h3>
        <ul class="flex flex-col gap-2.5 list-none">
          {
            company.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="footer-link text-[13px] text-(--muted) no-underline transition-colors duration-200 hover:text-(--text)"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna 4: Contacto -->
      <div>
        <h3
          class="font-['Syne'] text-[13px] font-semibold text-(--text) tracking-wide mb-4"
        >
          Contacto
        </h3>
        <div class="flex flex-col gap-3">
          <a
            href="mailto:devvhaj@gmail.com?subject=Contacto%20desde%20la%20web"
            class="footer-link inline-flex items-center gap-2 text-[13px] text-(--muted) no-underline transition-colors duration-200 hover:text-(--text)"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            devvhaj@gmail.com
          </a>
          <p class="inline-flex items-center gap-2 text-[13px] text-(--muted)">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
              ></path><circle cx="12" cy="10" r="3"></circle>
            </svg>
            Popayan - Cauca 🇨🇴
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[rgba(167,139,250,0.08)]">
    <div
      class="max-w-300 mx-auto px-5 sm:px-8 md:px-12 py-5 flex flex-col sm:flex-row items-center justify-between gap-3"
    >
      <p class="text-[12px] text-(--muted)">
        © 2026 VHAJ. Todos los derechos reservados.
      </p>
      <p class="text-[12px] text-(--muted)">Hecho con 💜 en Colombia</p>
    </div>
  </div>
</footer>

<style>
  .brand-gradient {
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: var(--muted);
    border: 1px solid rgba(167, 139, 250, 0.12);
    background: transparent;
    transition: all 0.2s;
  }

  .social-link:hover {
    color: var(--text);
    border-color: rgba(167, 139, 250, 0.35);
    background: rgba(167, 139, 250, 0.06);
  }
</style>
